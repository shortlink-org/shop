{
  "private": true,
  "sideEffects": [
    "**/*.css",
    "lib/temporal-polyfill.ts",
    "lib/ui-kit.ts"
  ],
  "pnpm": {
    "overrides": {
      "react": "19.2.5",
      "react-dom": "19.2.5"
    }
  },
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "pnpm next dev",
    "start": "NODE_ENV=production pnpm next start",
    "start:dev": "cp .env.dev .env && pnpm dev",
    "start:prod": "cp .env.prod .env && pnpm dev",
    "build": "NODE_ENV=production pnpm next build",
    "lint": "eslint .",
    "prettier": "pnpm dlx prettier --write --ignore-unknown .",
    "prettier:check": "pnpm dlx prettier --check --ignore-unknown .",
    "postinstall": "node scripts/patch-ui-kit-storefront.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@ory/client": "^1.22.35",
    "@tanstack/react-query": "^5.99.0",
    "@types/react-dom": "^19.2.3",
    "@vercel/otel": "^2.1.2",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.72.1",
    "redis": "^5.12.1",
    "sanitize-html": "^2.17.2",
    "sonner": "^2.0.7",
    "temporal-polyfill": "^0.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shortlink-org/ui-kit": "^0.20260407.113159",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.2",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  }
}
